# Copy to .env and fill in your values
DATABASE_URL=sqlite:///./inventory.db

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Home Depot API — uses SerpApi (https://serpapi.com), engine=home_depot_product
HOME_DEPOT_API_KEY=your_serpapi_key_here

# Lowe's API — uses SerpApi (https://serpapi.com), engine=lowes
LOWES_API_KEY=your_serpapi_key_here

# Amazon API — uses SerpApi (https://serpapi.com), engine=amazon_product / amazon
AMAZON_API_KEY=your_serpapi_key_here

# OCR — set one of these (checked in order: Groq → Gemini → OpenAI)
# Groq (free, no credit card): https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_key_here
# Google Gemini (free tier): https://aistudio.google.com → Get API key
GEMINI_API_KEY=your_gemini_key_here
# OpenAI GPT-4o Vision (paid): https://platform.openai.com → API keys
OPENAI_API_KEY=your_openai_key_here

# Upload directory
UPLOAD_DIR=./uploads
